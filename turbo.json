{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_SERVICE_ROLE",
    "NVIDIA_API_KEY",
    "ONRAMP_STUB_MODE",
    "X402_STUB_MODE",
    "STELLAR_NETWORK",
    "STELLAR_RPC_URL",
    "SOROBAN_CONTRACT_ID_ROUTER",
    "SOROBAN_CONTRACT_ID_VAULT",
    "AGENT_WALLET_SECRET_KEY",
    "ONRAMP_API_KEY",
    "ONRAMP_API_SECRET",
    "OPENAI_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
